---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import HeroSection from '../components/hero/HeroSection.astro';
import FeatureGrid from '../components/features/FeatureGrid.astro';
import DownloadSection from '../components/download/DownloadSection.astro';
---

<BaseLayout title="ColorClip Pro - Professional Color Management">
  <!-- Beta Banner -->
  <div class="bg-primary-600 text-white text-sm text-center py-2 px-4">
    <span class="inline-flex items-center gap-2">
      <span class="bg-white/20 text-white text-xs font-bold px-2 py-0.5 rounded-full uppercase tracking-wide">Beta</span>
      ColorClip Pro is currently in beta — expect rapid updates and the occasional rough edge.
      <a href="/releases" class="underline underline-offset-2 hover:text-white/80 font-medium transition-colors">See what's new →</a>
    </span>
  </div>

  <Navigation />

  <main>
    <!-- Hero Section -->
    <HeroSection />

    <!-- Features Section -->
    <div id="features">
      <FeatureGrid />
    </div>

    <!-- Download Section -->
    <div id="download">
      <DownloadSection />
    </div>
  </main>
</BaseLayout>
