---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import ReleaseNotes from '../components/ReleaseNotes';
---

<BaseLayout
  title="Release Notes - ColorClip Pro"
  description="ColorClip Pro release history, changelog, and version updates"
>
  <Navigation />
  <main class="bg-gray-50 min-h-screen">
    <div class="container-custom section">

      <!-- Page Header -->
      <div class="text-center max-w-2xl mx-auto mb-16">
        <h1 class="font-display font-bold text-gray-900 mb-4">Release Notes</h1>
        <p class="text-xl text-gray-600">
          Full version history for ColorClip Pro. All releases are open source and available on
          <a
            href="https://github.com/prouticus/colorclip-pro/releases"
            target="_blank"
            rel="noopener noreferrer"
            class="text-primary-600 hover:text-primary-700 underline transition-colors"
          >
            GitHub
          </a>.
        </p>
      </div>

      <!-- Release Cards -->
      <div class="max-w-3xl mx-auto">
        <ReleaseNotes client:load />
      </div>

    </div>
  </main>
</BaseLayout>
